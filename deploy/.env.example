# Anthropic — required. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
CLAUDE_MODEL=sonnet
# CLAUDE_MAX_TOKENS=1024

# Fish Audio TTS — optional (silent DJ patter if omitted)
FISH_AUDIO_API_KEY=
FISH_AUDIO_REFERENCE_ID=
FISH_AUDIO_MODEL=s1

# OpenWeather — optional (no weather context if omitted)
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Montreal

# Google OAuth client — required for sign-in AND per-user Calendar connect.
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include:
#   https://miaoradio.pilipalajing.com/api/auth/callback
#   https://miaoradio.pilipalajing.com/api/me/calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server
PORT=8080

# Public-facing URL — must be HTTPS in prod for Secure cookies + OAuth.
PUBLIC_URL=https://miaoradio.pilipalajing.com

# Auth — required.
# Generate with:  openssl rand -hex 32
SESSION_SECRET=

# Comma-separated invitation codes. Anyone with one of these can sign up.
INVITE_CODES=
